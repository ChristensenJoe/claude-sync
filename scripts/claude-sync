#!/usr/bin/env bash
set -euo pipefail

# Claude Code Configuration Sync
# Syncs global memories, commands, settings, CLAUDE.md, project memories,
# and branch notes between ~/.claude/ and a git-backed config repo.
#
# Usage:
#   claude-sync pull                      Pull config from repo to local ~/.claude/
#   claude-sync push                      Push local ~/.claude/ config to repo
#   claude-sync setup                     First-time setup on a new machine
#   claude-sync status                    Show what differs between local and repo
#   claude-sync add-project <name> [path] [options]  Register a project
#   claude-sync doctor                    Diagnose common configuration issues

# Resolve symlinks so this works when invoked via ~/.local/bin/claude-sync
SCRIPT_PATH="$0"
if [[ -L "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CLAUDE_DIR="$HOME/.claude"
LOCAL_CONFIG="$REPO_DIR/.local-config.json"
SYNC_RESULT="$REPO_DIR/.last-sync-result"

# ── Helpers ──────────────────────────────────────────────────────────────────

encode_path() {
  echo "$1" | tr '/' '-'
}

encode_branch() {
  # Normalize branch names for use as directory names
  # feature/billing → feature-billing
  echo "$1" | tr '/' '-'
}

ensure_jq() {
  if ! command -v jq &>/dev/null; then
    echo "ERROR: jq is required but not installed." >&2
    echo "Install it: brew install jq (macOS) or sudo apt install jq (Linux)" >&2
    return 1
  fi
}

ensure_local_config() {
  if [[ ! -f "$LOCAL_CONFIG" ]]; then
    echo '{"projects":{}}' | jq . > "$LOCAL_CONFIG"
  fi
}

# Get project path from config — handles both old string format and new object format
get_project_path() {
  local name="$1"
  local val
  val=$(jq -r --arg n "$name" '.projects[$n] // empty' "$LOCAL_CONFIG" 2>/dev/null)
  if [[ -z "$val" ]]; then
    return 1
  fi
  # Check if it's a string (old format) or object (new format)
  local type
  type=$(jq -r --arg n "$name" '.projects[$n] | type' "$LOCAL_CONFIG" 2>/dev/null)
  if [[ "$type" == "string" ]]; then
    echo "$val"
  else
    jq -r --arg n "$name" '.projects[$n].path // empty' "$LOCAL_CONFIG" 2>/dev/null
  fi
}

# Get project field from config (for new object format fields)
get_project_field() {
  local name="$1" field="$2"
  local type
  type=$(jq -r --arg n "$name" '.projects[$n] | type' "$LOCAL_CONFIG" 2>/dev/null)
  if [[ "$type" == "object" ]]; then
    jq -r --arg n "$name" --arg f "$field" '.projects[$n][$f] // empty' "$LOCAL_CONFIG" 2>/dev/null
  fi
}

# Iterate projects as "name" lines (just names, look up fields separately)
get_project_names() {
  if [[ -f "$LOCAL_CONFIG" ]]; then
    jq -r '.projects // {} | keys[]' "$LOCAL_CONFIG" 2>/dev/null
  fi
}

sync_dir() {
  local src="$1" dst="$2"
  if [[ -d "$src" ]]; then
    mkdir -p "$dst"
    rsync -a --delete "$src/" "$dst/"
  fi
}

sync_dir_no_delete() {
  local src="$1" dst="$2"
  if [[ -d "$src" ]]; then
    mkdir -p "$dst"
    rsync -a "$src/" "$dst/"
  fi
}

sync_file() {
  local src="$1" dst="$2"
  if [[ -f "$src" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
  fi
}

write_result() {
  echo "$1" >> "$SYNC_RESULT"
}

clear_result() {
  rm -f "$SYNC_RESULT"
}

# ── Settings Merge ───────────────────────────────────────────────────────────

merge_settings_on_pull() {
  local repo_settings="$REPO_DIR/global/settings.json"
  local local_settings="$CLAUDE_DIR/settings.json"

  if [[ ! -f "$repo_settings" ]]; then
    return 0
  fi

  if [[ ! -f "$local_settings" ]]; then
    cp "$repo_settings" "$local_settings"
    return 0
  fi

  local merged
  merged=$(jq -s '
    .[0] as $local | .[1] as $repo |
    $local * {
      hooks: ($repo.hooks // $local.hooks // {}),
      env: (($local.env // {}) * ($repo.env // {})),
      enabledPlugins: (($local.enabledPlugins // {}) * ($repo.enabledPlugins // {}))
    }
  ' "$local_settings" "$repo_settings")

  echo "$merged" | jq . > "$local_settings.tmp"
  mv "$local_settings.tmp" "$local_settings"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_pull() {
  clear_result

  if ! git -C "$REPO_DIR" pull --ff-only 2>"$SYNC_RESULT.git-err"; then
    write_result "SYNC ERROR: git pull failed"
    cat "$SYNC_RESULT.git-err" >> "$SYNC_RESULT" 2>/dev/null
    rm -f "$SYNC_RESULT.git-err"
    exit 0
  fi
  rm -f "$SYNC_RESULT.git-err"

  local changes=""

  # Sync global memory
  if [[ -d "$REPO_DIR/global/memory" ]]; then
    local before_mem=""
    if [[ -d "$CLAUDE_DIR/memory" ]]; then
      before_mem=$(find "$CLAUDE_DIR/memory" -type f -name "*.md" 2>/dev/null | sort)
    fi
    sync_dir "$REPO_DIR/global/memory" "$CLAUDE_DIR/memory"
    local after_mem=$(find "$CLAUDE_DIR/memory" -type f -name "*.md" 2>/dev/null | sort)
    if [[ "$before_mem" != "$after_mem" ]]; then
      changes="${changes}Updated global memories\n"
    fi
  fi

  # Sync global commands
  if [[ -d "$REPO_DIR/global/commands" ]]; then
    local before_cmd=""
    if [[ -d "$CLAUDE_DIR/commands" ]]; then
      before_cmd=$(find "$CLAUDE_DIR/commands" -type f -name "*.md" 2>/dev/null | sort)
    fi
    sync_dir "$REPO_DIR/global/commands" "$CLAUDE_DIR/commands"
    local after_cmd=$(find "$CLAUDE_DIR/commands" -type f -name "*.md" 2>/dev/null | sort)
    if [[ "$before_cmd" != "$after_cmd" ]]; then
      changes="${changes}Updated global commands\n"
    fi
  fi

  # Sync CLAUDE.md
  if [[ -f "$REPO_DIR/global/CLAUDE.md" ]]; then
    local changed_claude=false
    if [[ ! -f "$CLAUDE_DIR/CLAUDE.md" ]]; then
      changed_claude=true
    elif ! diff -q "$REPO_DIR/global/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md" &>/dev/null; then
      changed_claude=true
    fi
    sync_file "$REPO_DIR/global/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
    if $changed_claude; then
      changes="${changes}Updated global CLAUDE.md\n"
    fi
  fi

  # Merge settings
  if [[ -f "$REPO_DIR/global/settings.json" ]]; then
    local before_settings=""
    if [[ -f "$CLAUDE_DIR/settings.json" ]]; then
      before_settings=$(cat "$CLAUDE_DIR/settings.json")
    fi
    merge_settings_on_pull
    local after_settings=$(cat "$CLAUDE_DIR/settings.json")
    if [[ "$before_settings" != "$after_settings" ]]; then
      changes="${changes}Updated settings (hooks/env/plugins merged, permissions preserved)\n"
    fi
  fi

  # Sync project memories and branch notes
  ensure_local_config
  while read -r name; do
    [[ -z "$name" ]] && continue
    local path
    path=$(get_project_path "$name") || continue
    local encoded
    encoded=$(encode_path "$path")

    # Sync memory
    local repo_proj_mem="$REPO_DIR/projects/$name/memory"
    local local_proj_mem="$CLAUDE_DIR/projects/$encoded/memory"
    if [[ -d "$repo_proj_mem" ]]; then
      local before_proj=""
      if [[ -d "$local_proj_mem" ]]; then
        before_proj=$(find "$local_proj_mem" -type f -name "*.md" 2>/dev/null | sort)
      fi
      sync_dir "$repo_proj_mem" "$local_proj_mem"
      local after_proj=$(find "$local_proj_mem" -type f -name "*.md" 2>/dev/null | sort)
      if [[ "$before_proj" != "$after_proj" ]]; then
        changes="${changes}Updated project memories for '$name'\n"
      fi
    fi

    # Branch notes live in the repo and are read directly by Claude.
    # git pull already brought them up to date — just report if any exist.
    local repo_branches="$REPO_DIR/projects/$name/branches"
    if [[ -d "$repo_branches" ]] && [[ "$(find "$repo_branches" -name "notes.md" 2>/dev/null)" ]]; then
      local branch_count
      branch_count=$(find "$repo_branches" -name "notes.md" 2>/dev/null | wc -l | tr -d ' ')
      changes="${changes}Branch notes available for '$name' ($branch_count branch(es))\n"
    fi
  done < <(get_project_names)

  if [[ -n "$changes" ]]; then
    write_result "SYNC OK: Changes pulled:"
    echo -e "$changes" >> "$SYNC_RESULT"
  else
    write_result "SYNC OK: Already up to date"
  fi

  exit 0
}

cmd_push() {
  ensure_jq

  sync_dir "$CLAUDE_DIR/memory" "$REPO_DIR/global/memory"
  sync_dir "$CLAUDE_DIR/commands" "$REPO_DIR/global/commands"
  sync_file "$CLAUDE_DIR/CLAUDE.md" "$REPO_DIR/global/CLAUDE.md"
  sync_file "$CLAUDE_DIR/settings.json" "$REPO_DIR/global/settings.json"

  ensure_local_config
  while read -r name; do
    [[ -z "$name" ]] && continue
    local path
    path=$(get_project_path "$name") || continue
    local encoded
    encoded=$(encode_path "$path")

    # Sync memory
    local local_proj_mem="$CLAUDE_DIR/projects/$encoded/memory"
    local repo_proj_mem="$REPO_DIR/projects/$name/memory"
    if [[ -d "$local_proj_mem" ]]; then
      sync_dir "$local_proj_mem" "$repo_proj_mem"
    fi

    # Branch notes stay in the repo — no local copy needed, they're written
    # directly to the repo by /recap
  done < <(get_project_names)

  cd "$REPO_DIR"
  git add -A
  if git diff --cached --quiet; then
    echo "Nothing to push — already in sync."
    return 0
  fi

  local timestamp
  timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')
  git commit -m "sync: $timestamp"
  git push

  echo "Pushed config sync at $timestamp"
}

cmd_setup() {
  ensure_jq

  echo "Setting up Claude Code config sync..."
  echo ""

  mkdir -p "$CLAUDE_DIR/memory"
  mkdir -p "$CLAUDE_DIR/commands"

  ensure_local_config

  if [[ -d "$REPO_DIR/global/memory" ]] && [[ "$(ls -A "$REPO_DIR/global/memory" 2>/dev/null)" ]]; then
    echo "  Pulling global config from repo..."
    sync_dir "$REPO_DIR/global/memory" "$CLAUDE_DIR/memory"
    sync_dir_no_delete "$REPO_DIR/global/commands" "$CLAUDE_DIR/commands"
    sync_file "$REPO_DIR/global/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
    merge_settings_on_pull
  else
    echo "  No existing config in repo — copying template defaults..."
    sync_dir_no_delete "$REPO_DIR/global/commands" "$CLAUDE_DIR/commands"
    sync_file "$REPO_DIR/global/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
    merge_settings_on_pull
  fi

  # Sync project memories
  while read -r name; do
    [[ -z "$name" ]] && continue
    local path
    path=$(get_project_path "$name") || continue
    local encoded
    encoded=$(encode_path "$path")
    local repo_proj_mem="$REPO_DIR/projects/$name/memory"
    local local_proj_mem="$CLAUDE_DIR/projects/$encoded/memory"

    if [[ -d "$repo_proj_mem" ]]; then
      mkdir -p "$local_proj_mem"
      sync_dir "$repo_proj_mem" "$local_proj_mem"
      echo "  Synced project memories for '$name'"
    fi
  done < <(get_project_names)

  # Install session-start hooks
  local settings="$CLAUDE_DIR/settings.json"
  if [[ ! -f "$settings" ]]; then
    echo '{}' > "$settings"
  fi

  if jq -e '[.hooks.SessionStart[]?.hooks[]? | select(.command? // "" | contains("claude-sync"))] | length > 0' "$settings" &>/dev/null; then
    echo "  Session-start sync hook already installed."
  else
    echo "  Installing session-start hooks..."
    local sync_hook
    sync_hook=$(cat <<'HOOKJSON'
{
  "matcher": "startup",
  "hooks": [
    {
      "type": "command",
      "command": "$HOME/claude-sync/scripts/claude-sync pull"
    },
    {
      "type": "agent",
      "prompt": "Check if the file at ~/claude-sync/.last-sync-result exists. If it does, read it and report to the user: if sync succeeded, summarize what changed (new/updated memories, commands, settings, project memories). If sync failed, tell the user what went wrong (network issue, git conflict, etc.) so they can fix it — but don't block the session. Then delete the file. If the file doesn't exist, say nothing about sync."
    }
  ]
}
HOOKJSON
    )

    local notes_hook
    notes_hook=$(cat <<'HOOKJSON'
{
  "matcher": "startup",
  "hooks": [
    {
      "type": "agent",
      "prompt": "Check for branch notes for the current project.\n\n1. Read the file at ~/claude-sync/.local-config.json. If it doesn't exist, say nothing and stop.\n2. Run `git remote get-url origin 2>/dev/null` in the current directory. If this fails (not a git repo), say nothing and stop.\n3. Match the remote URL against the `remote` field of each project in .local-config.json. If no match, say nothing and stop.\n4. Run `git branch --show-current` to get the branch name. Replace `/` with `-` in the branch name.\n5. Based on the project's `notes_source` (default is `sync`):\n   - sync: Read ~/claude-sync/projects/<project-name>/branches/<branch-name>/notes.md\n   - notion: Run `curl -s -H \"Authorization: Bearer $NOTION_API_KEY\" -H \"Notion-Version: 2022-06-28\" \"https://api.notion.com/v1/blocks/<notion_page_id>/children\"` and summarize the content.\n   - obsidian: Read the file at <obsidian_vault>/<obsidian_note>\n6. If notes exist, provide a concise summary of where things stand. If the file doesn't exist or is empty, say nothing."
    }
  ]
}
HOOKJSON
    )

    local updated
    # Remove existing branch notes hooks (if re-running setup), then install fresh
    updated=$(jq --argjson sync "$sync_hook" --argjson notes "$notes_hook" '
      .hooks.SessionStart = (
        [.hooks.SessionStart[]? | select(
          (.hooks[]?.prompt? // "" | contains("branch notes")) | not
        )] +
        [$notes, $sync]
      )
    ' "$settings")
    echo "$updated" | jq . > "$settings.tmp"
    mv "$settings.tmp" "$settings"
  fi

  # Install CLI symlink
  local bin_dir="$HOME/.local/bin"
  mkdir -p "$bin_dir"
  local symlink="$bin_dir/claude-sync"

  if [[ -L "$symlink" ]] || [[ -e "$symlink" ]]; then
    rm -f "$symlink"
  fi
  ln -s "$REPO_DIR/scripts/claude-sync" "$symlink"
  echo "  Installed claude-sync CLI at $symlink"

  # Ensure ~/.local/bin is in PATH
  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$bin_dir"; then
    local shell_rc=""
    case "$(basename "${SHELL:-/bin/bash}")" in
      zsh)  shell_rc="$HOME/.zshrc" ;;
      bash)
        if [[ -f "$HOME/.bashrc" ]]; then
          shell_rc="$HOME/.bashrc"
        else
          shell_rc="$HOME/.profile"
        fi
        ;;
      *)    shell_rc="$HOME/.profile" ;;
    esac

    if [[ -n "$shell_rc" ]] && ! grep -q '\.local/bin' "$shell_rc" 2>/dev/null; then
      echo '' >> "$shell_rc"
      echo '# Added by claude-sync setup' >> "$shell_rc"
      echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$shell_rc"
      echo "  Added ~/.local/bin to PATH in $shell_rc"
      echo "  Run 'source $shell_rc' or open a new terminal for it to take effect."
    fi
  fi

  echo ""
  echo "Setup complete!"
  echo ""
  echo "Next steps:"
  echo "  1. Register projects you work on:"
  echo "     claude-sync add-project my-app /path/to/my-app"
  echo ""
  echo "  2. Push your initial config:"
  echo "     claude-sync push"
  echo ""
  echo "  3. Start a Claude Code session — sync and branch notes load automatically"
  echo ""
  echo "  4. Run 'claude-sync doctor' to verify everything is configured correctly"
}

cmd_status() {
  ensure_jq
  local any_diff=false

  echo "=== Claude Config Sync Status ==="
  echo ""

  if diff -rq "$CLAUDE_DIR/memory/" "$REPO_DIR/global/memory/" &>/dev/null; then
    echo "  Global memory:    in sync"
  else
    echo "  Global memory:    DIFFERS"
    any_diff=true
  fi

  if [[ -d "$CLAUDE_DIR/commands" ]] && [[ -d "$REPO_DIR/global/commands" ]]; then
    if diff -rq "$CLAUDE_DIR/commands/" "$REPO_DIR/global/commands/" &>/dev/null; then
      echo "  Global commands:  in sync"
    else
      echo "  Global commands:  DIFFERS"
      any_diff=true
    fi
  elif [[ -d "$CLAUDE_DIR/commands" ]]; then
    echo "  Global commands:  local only (not yet pushed)"
    any_diff=true
  else
    echo "  Global commands:  (none)"
  fi

  if [[ -f "$CLAUDE_DIR/CLAUDE.md" ]] && [[ -f "$REPO_DIR/global/CLAUDE.md" ]]; then
    if diff -q "$CLAUDE_DIR/CLAUDE.md" "$REPO_DIR/global/CLAUDE.md" &>/dev/null; then
      echo "  Global CLAUDE.md: in sync"
    else
      echo "  Global CLAUDE.md: DIFFERS"
      any_diff=true
    fi
  elif [[ -f "$CLAUDE_DIR/CLAUDE.md" ]]; then
    echo "  Global CLAUDE.md: local only (not yet pushed)"
    any_diff=true
  else
    echo "  Global CLAUDE.md: (none)"
  fi

  if [[ -f "$REPO_DIR/global/settings.json" ]]; then
    if diff -q "$CLAUDE_DIR/settings.json" "$REPO_DIR/global/settings.json" &>/dev/null; then
      echo "  Settings:         in sync"
    else
      echo "  Settings:         DIFFERS (permissions may intentionally differ)"
      any_diff=true
    fi
  else
    echo "  Settings:         not yet pushed"
    any_diff=true
  fi

  echo ""
  ensure_local_config
  local has_projects=false
  while read -r name; do
    [[ -z "$name" ]] && continue
    has_projects=true
    local path
    path=$(get_project_path "$name") || continue
    local encoded
    encoded=$(encode_path "$path")
    local local_proj="$CLAUDE_DIR/projects/$encoded/memory"
    local repo_proj="$REPO_DIR/projects/$name/memory"
    local notes_source
    notes_source=$(get_project_field "$name" "notes_source")
    notes_source="${notes_source:-sync}"

    # Memory status
    if [[ -d "$local_proj" ]] && [[ -d "$repo_proj" ]]; then
      if diff -rq "$local_proj/" "$repo_proj/" &>/dev/null; then
        echo "  Project '$name': memory in sync"
      else
        echo "  Project '$name': memory DIFFERS"
        any_diff=true
      fi
    elif [[ -d "$local_proj" ]]; then
      echo "  Project '$name': memory local only"
      any_diff=true
    elif [[ -d "$repo_proj" ]]; then
      echo "  Project '$name': memory repo only"
      any_diff=true
    fi

    # Branch notes info
    local branch_count=0
    if [[ -d "$REPO_DIR/projects/$name/branches" ]]; then
      branch_count=$(find "$REPO_DIR/projects/$name/branches" -name "notes.md" 2>/dev/null | wc -l | tr -d ' ')
    fi
    echo "  Project '$name': $branch_count branch note(s), source=$notes_source"
  done < <(get_project_names)

  if ! $has_projects; then
    echo "  Projects:         (none registered — use 'claude-sync add-project')"
  fi

  echo ""
  if $any_diff; then
    echo "Run 'claude-sync push' to upload, or 'claude-sync pull' to download."
  else
    echo "Everything is in sync."
  fi
}

cmd_add_project() {
  local name=""
  local path=""
  local notes_source="sync"
  local notion_page_id=""
  local obsidian_vault=""
  local obsidian_note=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --notes)       notes_source="$2"; shift 2 ;;
      --notion-page) notion_page_id="$2"; shift 2 ;;
      --obsidian-vault) obsidian_vault="$2"; shift 2 ;;
      --obsidian-note)  obsidian_note="$2"; shift 2 ;;
      -*)
        echo "Unknown option: $1" >&2
        return 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$path" ]]; then
          path="$1"
        fi
        shift
        ;;
    esac
  done

  path="${path:-$(pwd)}"

  if [[ -z "$name" ]]; then
    echo "Usage: claude-sync add-project <name> [path] [options]" >&2
    echo "" >&2
    echo "  name                    Canonical project identifier (e.g., my-app)" >&2
    echo "  path                    Absolute path to project (defaults to cwd)" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  --notes sync|notion|obsidian   Note source (default: sync)" >&2
    echo "  --notion-page ID               Notion page ID (required for notion)" >&2
    echo "  --obsidian-vault PATH          Obsidian vault path (required for obsidian)" >&2
    echo "  --obsidian-note PATH           Note path within vault (required for obsidian)" >&2
    return 1
  fi

  # Validate notes source config
  case "$notes_source" in
    sync) ;;
    notion)
      if [[ -z "$notion_page_id" ]]; then
        echo "ERROR: --notion-page is required when using --notes notion" >&2
        return 1
      fi
      ;;
    obsidian)
      if [[ -z "$obsidian_vault" ]] || [[ -z "$obsidian_note" ]]; then
        echo "ERROR: --obsidian-vault and --obsidian-note are required when using --notes obsidian" >&2
        return 1
      fi
      ;;
    *)
      echo "ERROR: --notes must be sync, notion, or obsidian" >&2
      return 1
      ;;
  esac

  if [[ ! -d "$path" ]]; then
    echo "ERROR: Path does not exist: $path" >&2
    return 1
  fi
  path="$(cd "$path" && pwd)"

  ensure_jq
  ensure_local_config

  # Auto-detect git remote
  local remote=""
  if git -C "$path" remote get-url origin &>/dev/null; then
    remote=$(git -C "$path" remote get-url origin 2>/dev/null)
  fi

  # Build project config object
  local project_json
  project_json=$(jq -n \
    --arg path "$path" \
    --arg remote "$remote" \
    --arg notes_source "$notes_source" \
    --arg notion_page_id "$notion_page_id" \
    --arg obsidian_vault "$obsidian_vault" \
    --arg obsidian_note "$obsidian_note" \
    '{path: $path, remote: $remote, notes_source: $notes_source} +
     (if $notion_page_id != "" then {notion_page_id: $notion_page_id} else {} end) +
     (if $obsidian_vault != "" then {obsidian_vault: $obsidian_vault} else {} end) +
     (if $obsidian_note != "" then {obsidian_note: $obsidian_note} else {} end)')

  local updated
  updated=$(jq --arg name "$name" --argjson proj "$project_json" '
    .projects[$name] = $proj
  ' "$LOCAL_CONFIG")
  echo "$updated" | jq . > "$LOCAL_CONFIG.tmp"
  mv "$LOCAL_CONFIG.tmp" "$LOCAL_CONFIG"

  local encoded
  encoded=$(encode_path "$path")
  echo "Registered project '$name'"
  echo "  Path:         $path"
  echo "  Remote:       ${remote:-<none detected>}"
  echo "  Notes source: $notes_source"

  mkdir -p "$REPO_DIR/projects/$name/memory"
  mkdir -p "$REPO_DIR/projects/$name/branches"

  # Sync memories
  local local_proj_mem="$CLAUDE_DIR/projects/$encoded/memory"
  local repo_proj_mem="$REPO_DIR/projects/$name/memory"

  if [[ -d "$local_proj_mem" ]] && [[ "$(ls -A "$local_proj_mem" 2>/dev/null)" ]]; then
    echo "Copying local project memories to repo..."
    sync_dir "$local_proj_mem" "$repo_proj_mem"
  elif [[ -d "$repo_proj_mem" ]] && [[ "$(ls -A "$repo_proj_mem" 2>/dev/null)" ]]; then
    echo "Copying repo project memories to local..."
    mkdir -p "$local_proj_mem"
    sync_dir "$repo_proj_mem" "$local_proj_mem"
  else
    echo "No existing memories found — they'll sync on next push/pull."
  fi

  echo ""
  echo "Done. Run 'claude-sync push' to upload."
}

cmd_doctor() {
  echo "=== Claude Sync Doctor ==="
  echo ""
  local issues=0

  if command -v jq &>/dev/null; then
    echo "  [OK] jq is installed ($(jq --version 2>&1))"
  else
    echo "  [!!] jq is NOT installed"
    echo "       Install: brew install jq (macOS) or sudo apt install jq (Linux)"
    ((issues++))
  fi

  if command -v git &>/dev/null; then
    echo "  [OK] git is installed ($(git --version 2>&1 | head -1))"
  else
    echo "  [!!] git is NOT installed"
    ((issues++))
  fi

  if command -v rsync &>/dev/null; then
    echo "  [OK] rsync is installed"
  else
    echo "  [!!] rsync is NOT installed"
    ((issues++))
  fi

  if [[ -d "$CLAUDE_DIR" ]]; then
    echo "  [OK] ~/.claude/ directory exists"
  else
    echo "  [!!] ~/.claude/ directory does NOT exist"
    ((issues++))
  fi

  if [[ -f "$CLAUDE_DIR/settings.json" ]]; then
    echo "  [OK] ~/.claude/settings.json exists"
  else
    echo "  [!!] ~/.claude/settings.json does NOT exist"
    ((issues++))
  fi

  if [[ -f "$CLAUDE_DIR/settings.json" ]] && jq -e '[.hooks.SessionStart[]?.hooks[]? | select(.command? // "" | contains("claude-sync"))] | length > 0' "$CLAUDE_DIR/settings.json" &>/dev/null; then
    echo "  [OK] Session-start sync hook is installed"
  else
    echo "  [!!] Session-start sync hook is NOT installed"
    ((issues++))
  fi

  if [[ -f "$CLAUDE_DIR/settings.json" ]] && jq -e '[.hooks.SessionStart[]?.hooks[]? | select(.prompt? // "" | contains("branch notes"))] | length > 0' "$CLAUDE_DIR/settings.json" &>/dev/null; then
    echo "  [OK] Branch notes session-start hook is installed"
  else
    echo "  [--] Branch notes session-start hook is not installed (run setup)"
  fi

  if [[ -d "$CLAUDE_DIR/commands" ]] && [[ "$(ls -A "$CLAUDE_DIR/commands" 2>/dev/null)" ]]; then
    local cmd_count
    cmd_count=$(find "$CLAUDE_DIR/commands" -name "*.md" | wc -l | tr -d ' ')
    echo "  [OK] $cmd_count global commands installed in ~/.claude/commands/"
  else
    echo "  [!!] No global commands installed"
    ((issues++))
  fi

  if [[ -f "$CLAUDE_DIR/CLAUDE.md" ]]; then
    echo "  [OK] Global ~/.claude/CLAUDE.md exists"
  else
    echo "  [--] No global ~/.claude/CLAUDE.md (optional — run setup to create one)"
  fi

  # Check CLI symlink
  if [[ -L "$HOME/.local/bin/claude-sync" ]]; then
    echo "  [OK] claude-sync CLI symlink installed"
  else
    echo "  [--] claude-sync CLI symlink not installed (run setup to add it)"
  fi

  if echo "$PATH" | tr ':' '\n' | grep -qx "$HOME/.local/bin"; then
    echo "  [OK] ~/.local/bin is in PATH"
  else
    echo "  [!!] ~/.local/bin is NOT in PATH"
    echo "       Run setup or add 'export PATH=\"\$HOME/.local/bin:\$PATH\"' to your shell rc"
    ((issues++))
  fi

  if git -C "$REPO_DIR" remote get-url origin &>/dev/null; then
    local remote
    remote=$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null)
    echo "  [OK] Git remote configured: $remote"
  else
    echo "  [!!] No git remote configured"
    ((issues++))
  fi

  # Check projects
  ensure_local_config
  local proj_count
  proj_count=$(jq '.projects | length' "$LOCAL_CONFIG" 2>/dev/null || echo 0)
  if [[ "$proj_count" -gt 0 ]]; then
    echo "  [OK] $proj_count project(s) registered"
    while read -r name; do
      [[ -z "$name" ]] && continue
      local path
      path=$(get_project_path "$name") || continue
      local notes_source
      notes_source=$(get_project_field "$name" "notes_source")
      notes_source="${notes_source:-sync}"
      local remote
      remote=$(get_project_field "$name" "remote")

      local status_line="       - $name: $path (notes=$notes_source)"
      if [[ ! -d "$path" ]]; then
        status_line="$status_line [PATH NOT FOUND]"
        ((issues++))
      fi
      echo "$status_line"

      # Validate notes source config
      case "$notes_source" in
        notion)
          local page_id
          page_id=$(get_project_field "$name" "notion_page_id")
          if [[ -z "$page_id" ]]; then
            echo "         [!!] Notion page ID not configured"
            ((issues++))
          fi
          if [[ -z "${NOTION_API_KEY:-}" ]]; then
            echo "         [!!] NOTION_API_KEY environment variable not set"
            ((issues++))
          fi
          ;;
        obsidian)
          local vault
          vault=$(get_project_field "$name" "obsidian_vault")
          if [[ -z "$vault" ]]; then
            echo "         [!!] Obsidian vault path not configured"
            ((issues++))
          elif [[ ! -d "$vault" ]]; then
            echo "         [!!] Obsidian vault not found: $vault"
            ((issues++))
          fi
          ;;
      esac
    done < <(get_project_names)
  else
    echo "  [--] No projects registered (use 'claude-sync add-project' to add one)"
  fi

  echo ""
  if [[ $issues -eq 0 ]]; then
    echo "All checks passed. Your setup looks good!"
  else
    echo "$issues issue(s) found. Run 'claude-sync setup' to fix most of them."
  fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  pull)      cmd_pull ;;
  push)      cmd_push ;;
  setup)     cmd_setup ;;
  status)    cmd_status ;;
  doctor)    cmd_doctor ;;
  add-project)
    shift
    cmd_add_project "$@"
    ;;
  *)
    echo "Claude Code Configuration Sync"
    echo ""
    echo "Usage: claude-sync <command>"
    echo ""
    echo "Commands:"
    echo "  pull                              Pull config from repo to ~/.claude/"
    echo "  push                              Push ~/.claude/ config to repo"
    echo "  setup                             First-time setup on a new machine"
    echo "  status                            Show what differs between local and repo"
    echo "  add-project <name> [path] [opts]  Register a project"
    echo "  doctor                            Diagnose configuration issues"
    echo ""
    echo "Add-project options:"
    echo "  --notes sync|notion|obsidian      Note source (default: sync)"
    echo "  --notion-page ID                  Notion page ID"
    echo "  --obsidian-vault PATH             Obsidian vault path"
    echo "  --obsidian-note PATH              Note path within vault"
    ;;
esac
